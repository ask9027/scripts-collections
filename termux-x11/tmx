#!/data/data/com.termux/files/usr/bin/bash

#######################################
# CONFIG
#######################################
ROOT_MODE=$(id -u)
ROOT_CMD="su -c"
EXTRA_OPTS=""
server_pid=""

#######################################
# COLORS
#######################################
RED='\033[31m'
GREEN='\033[32m'
CYAN='\033[36m'
YELLOW='\033[33m'
RESET='\033[0m'

trap cleanup INT TERM

#######################################
# CTRL+C HANDLER (STOP ONLY)
#######################################
cleanup() {
    echo
    printf "${RED}[!] Stopping Termux-X11...${RESET}"; echo
    get_server_pid
    if [ -n "$server_pid" ]; then
        if [ "$ROOT_MODE" -eq 0 ]; then
            printf "${YELLOW}[!] Killing server at $server_pid${RESET}"; echo
	    $ROOT_CMD "kill $server_pid" || true
	    [ -n "${TMPDIR:-}" ] && $ROOT_CMD "rm -rf ${TMPDIR}/.X*"
            $ROOT_CMD "setenforce 1" || true
	    printf "${YELLOW}[✓] Set back Enforce to ${GREEN}$($ROOT_CMD getenforce)${RESET}"; echo
        else
            printf "${YELLOW}[!] Killing server at $server_pid${RESET}"; echo
	    kill $server_pid || true
	    [ -n "${TMPDIR:-}" ] && rm -rf "${TMPDIR}/.X*"
        fi
	printf "${GREEN}[✓] XServer stopped${RESET}"; echo
    else
	printf "${GREEN}[✓] XServer already stopped${RESET}"; echo
    fi
    exit 0
}

#######################################
# CHECK RUNNING
#######################################

get_server_pid() {
    if [ "$ROOT_MODE" -eq 0 ]; then
        server_pid=$($ROOT_CMD "pidof com.termux-x11")
    else
	server_pid=$(pgrep com.termux-x11)
    fi
}

check_server() {
    get_server_pid

    if [ -n "$server_pid" ]; then
        printf "${RED}[!] XServer is already running at PID: ${server_pid}\n"; echo
        printf "${CYAN}[-] To terminate, run: \`kill $server_pid\`${RESET}\n"; echo
        exit 0
    else
        printf "${GREEN}[✓] No XServer instance running.${RESET}"; echo
    fi
}

#######################################
# ARGUMENTS (FIXED)
#######################################
while [ $# -gt 0 ]; do
    case "$1" in
        -r|--root)
            ROOT_MODE=0
            ;;
        -d|--debug)
            export TERMUX_X11_DEBUG=1
            ;;
        *)
            EXTRA_OPTS="$EXTRA_OPTS $1"
            ;;
    esac
    shift
done

check_server

#######################################
# START X11 (NO FORCE-STOP HERE)
#######################################
start_x11() {
    APK_PATH="/data/data/com.termux/files/usr/libexec/termux-x11/loader.apk"
    if [ ! -f "$APK_PATH" ]; then
        printf "${RED}[!] Termux-X11 not installed${RESET}"; echo
        exit 1
    fi

    export CLASSPATH="$APK_PATH"
    unset LD_LIBRARY_PATH LD_PRELOAD

    printf "${GREEN}[✓] Starting Termux-X11${RESET}"; echo

    /system/bin/app_process -Xnoimage-dex2oat / --nice-name=com.termux-x11 com.termux.x11.Loader $EXTRA_OPTS
}

start_x11_root() {
    APK_PATH=$($ROOT_CMD "pm path com.termux.x11 | cut -d: -f2")

    if [ -z "$APK_PATH" ]; then
        printf "${RED}[!] Termux-X11 not installed${RESET}"; echo
        exit 1
    fi

    export CLASSPATH="$APK_PATH"

    printf "${GREEN}[✓] Starting Termux-X11${RESET}"; echo

    $ROOT_CMD "/system/bin/app_process -Xnoimage-dex2oat / --nice-name=com.termux-x11 com.termux.x11.CmdEntryPoint $EXTRA_OPTS"
}

#######################################
# MAIN
#######################################
logcat -c || true

if [ "$ROOT_MODE" -eq 0 ]; then
    printf "${CYAN}[+] Running as ROOT${RESET}"; echo
    $ROOT_CMD "setenforce 0"
    printf "${YELLOW}[✓] Set Enforce to ${RED}$($ROOT_CMD getenforce)${RESET}"; echo
    start_x11_root
else
    printf "${CYAN}[+] Running as TERMUX USER${RESET}"; echo
    start_x11
fi
