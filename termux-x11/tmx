#!/data/data/com.termux/files/usr/bin/bash

#######################################
# CONFIG
#######################################
ROOT_MODE=$(id -u)
ROOT_CMD="su -c"
EXTRA_OPTS=""
server_pid=""

#######################################
# COLORS
#######################################
RED='\033[31m'
GREEN='\033[32m'
CYAN='\033[36m'
YELLOW='\033[33m'
RESET='\033[0m'

trap cleanup INT TERM

#######################################
# CTRL+C HANDLER (STOP ONLY)
#######################################
cleanup() {
    echo
    echo -e "${RED}[!] Stopping Termux-X11...${RESET}"
    get_server_pid
    if [ -n "$server_pid" ]; then
        if [ "$ROOT_MODE" -eq 0 ]; then
            echo -e "${YELLOW}[✓] Killing server at $server_pid${RESET}"
	    $ROOT_CMD "kill $server_pid" || true
	    [ -n "${TMPDIR:-}" ] && $ROOT_CMD "rm -rf ${TMPDIR}/.X*"
            $ROOT_CMD "setenforce 1" || true
	    echo -e "${YELLOW}[+] Set Enforce to ${GREEN}$($ROOT_CMD getenforce)${RESET}"
        else
	    echo "non-root"
            echo -e "${YELLOW}[✓] Killing server at $server_pid${RESET}"
	    kill $server_pid || true
	    [ -n "${TMPDIR:-}" ] && rm -rf "${TMPDIR}/.X*"
        fi
	echo -e "${GREEN}[✓] XServer stopped${RESET}"
    else
	echo -e "${GREEN}[✓] XServer already stopped${RESET}"
    fi
    exit 0
}

#######################################
# CHECK RUNNING
#######################################

get_server_pid() {
    if [ "$ROOT_MODE" -eq 0 ]; then
        server_pid=$($ROOT_CMD "pidof com.termux-x11")
    else
	server_pid=$(pgrep com.termux-x11)
    fi
}

check_server() {
    get_server_pid

    if [ -n "$server_pid" ]; then
        printf "${RED}[!] XServer is already running at PID: ${server_pid}\n"
        printf "${CYAN}[-] To terminate, run: \`kill $server_pid\`${RESET}\n"
        exit 0
    else
        echo "[✓] No XServer instance running."
    fi
}

#######################################
# ARGUMENTS (FIXED)
#######################################
while [ $# -gt 0 ]; do
    case "$1" in
        -r|--root)
            ROOT_MODE=0
            ;;
        -d|--debug)
            export TERMUX_X11_DEBUG=1
            ;;
        *)
            EXTRA_OPTS="$EXTRA_OPTS $1"
            ;;
    esac
    shift
done

check_server

#######################################
# START X11 (NO FORCE-STOP HERE)
#######################################
start_x11() {
    APK_PATH="/data/data/com.termux/files/usr/libexec/termux-x11/loader.apk"
    if [ ! -f "$APK_PATH" ]; then
        echo -e "${RED}[!] Termux-X11 not installed${RESET}"
        exit 1
    fi

    export CLASSPATH="$APK_PATH"
    unset LD_LIBRARY_PATH LD_PRELOAD

    echo -e "${GREEN}[✓] Starting Termux-X11${RESET}"

    /system/bin/app_process -Xnoimage-dex2oat / \
        --nice-name=com.termux-x11 \
        com.termux.x11.Loader $EXTRA_OPTS
}

start_x11_root() {
    APK_PATH="$(pm path com.termux.x11 | cut -d: -f2)"

    if [ -z "$APK_PATH" ]; then
        echo -e "${RED}[!] Termux-X11 not installed${RESET}"
        exit 1
    fi

    export CLASSPATH="$APK_PATH"

    echo -e "${GREEN}[✓] Starting Termux-X11${RESET}"

    exec /system/bin/app_process -Xnoimage-dex2oat / \
        --nice-name=com.termux-x11 \
        com.termux.x11.CmdEntryPoint $EXTRA_OPTS
}

#######################################
# MAIN
#######################################
logcat -c || true

if [ "$ROOT_MODE" -eq 0 ]; then
    echo -e "${CYAN}[+] Running as ROOT${RESET}"
    $ROOT_CMD "setenforce 0"
    echo -e "${YELLOW}[✓] Set Enforce to ${RED}$($ROOT_CMD getenforce)${RESET}"
    $ROOT_CMD "$(declare -f start_x11_root); start_x11_root"
else
    echo -e "${CYAN}[+] Running as TERMUX USER${RESET}"
    start_x11
fi

